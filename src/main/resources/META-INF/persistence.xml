<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="MountainsWebAppDB" transaction-type="JTA">
        <jta-data-source>jdbc/MountainsWebAppDB</jta-data-source>

        <class>com.mountainswebapp.cs5003coursework2mountainswebapplicationproject.entities.Users</class>
        <properties>

            <property name="eclipselink.logging.level" value="FINE"/>
            <property name="eclipselink.ddl-generation" value="drop-and-update-tables"/>
        </properties>
    </persistence-unit>
</persistence>